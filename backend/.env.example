# ═══════════════════════════════════════════════
#  Backend Environment Variables — EXAMPLE FILE
#  Sao chép file này thành .env và điền thông tin thực tế
#  DO NOT commit .env — chỉ commit file này
# ═══════════════════════════════════════════════

# PostgreSQL Connection
# Keep value in ONE line only (no quotes, no trailing spaces/newlines)
# Local:
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/Sentiment_Analysis
# Supabase pooler (recommended in production):
# DATABASE_URL=postgresql+asyncpg://postgres.xxxxx:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# DB SSL mode: auto | disable | require | verify-full
# - auto: localhost => disable, server => verify-full, Supabase pooler => require
# - require: encrypt TLS without certificate verification
# - verify-full: strict certificate verification (optional DB_SSL_CA_FILE)
DB_SSL_MODE=auto
DB_SSL_CA_FILE=

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:5173

# App Info
APP_NAME=AI Sentiment Analysis API
APP_VERSION=1.0.0
DEBUG=False

# SMTP Email (Password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=SentimentAI

# Email Provider: smtp | resend | auto
# - smtp: use SMTP only
# - resend: use Resend API only (HTTPS 443)
# - auto: try SMTP then fallback Resend
EMAIL_PROVIDER=smtp
RESEND_API_KEY=
# Example: onboarding@resend.dev or no-reply@yourdomain.com
RESEND_FROM_EMAIL=
